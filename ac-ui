def render(lines):
    # Minimize flicker by reusing the screen and only clearing to end of line.
    size = shutil.get_terminal_size(fallback=(80, 24))
    width = size.columns
    height = size.lines
    sys.stdout.write("\033[H")
    # Ensure we never write more than the screen height
    if len(lines) < height:
        lines = lines + [""] * (height - len(lines))
    elif len(lines) > height:
        lines = lines[:height]
    for idx, line in enumerate(lines):
        # Avoid auto-wrap at terminal width (visible chars only)
        if visible_len(line) >= width:
            line = truncate_ansi_visible(line, max(0, width - 1))
        sys.stdout.write(line + "\033[K")
        if idx < height - 1:
            sys.stdout.write("\n")
    sys.stdout.write("\033[J")
    sys.stdout.flush()

def _read_key(fd, timeout=0.1):
    r, _, _ = select.select([fd], [], [], timeout)
    if not r:
        return None
    try:
        ch = os.read(fd, 1).decode("utf-8", errors="ignore")
    except Exception:
        return None
    if ch != "\x1b":
        return ch
    # Read escape sequence (arrows)
    seq = ""
    r, _, _ = select.select([fd], [], [], 0.01)
    if r:
        try:
            seq += os.read(fd, 1).decode("utf-8", errors="ignore")
        except Exception:
            pass
    r, _, _ = select.select([fd], [], [], 0.01)
    if r:
        try:
            seq += os.read(fd, 1).decode("utf-8", errors="ignore")
        except Exception:
            pass
    if seq.startswith("["):
        if seq.endswith("A"):
            return "UP"
        if seq.endswith("B"):
            return "DOWN"
        if seq.endswith("C"):
            return "RIGHT"
        if seq.endswith("D"):
            return "LEFT"
    return "ESC"

def _render_tune_editor(notes, cursor, status=None):
    size = shutil.get_terminal_size(fallback=(80, 24))
    term_cols = size.columns
    term_rows = size.lines

    row_w = 8
    cell_w = 3
    gap = 1
    staff_h = len(TOWN_TUNE_NOTES)
    total_w = row_w * cell_w + (row_w - 1) * gap
    pad = max(0, (term_cols - total_w) // 2)
    pad_s = " " * pad
    required_rows = staff_h * 2 + 8

    def compact():
        def token(tok):
            if tok == TOWN_TUNE_REST:
                return "--"
            if tok == TOWN_TUNE_HOLD:
                return "=="
            return tok
        def build_row(start_idx):
            row = []
            for i in range(start_idx, start_idx + row_w):
                tok = token(notes[i])
                cell = f"[{tok:2}]" if i == cursor else f" {tok:2} "
                row.append(cell)
            return pad_s + " ".join(row)
        lines = []
        lines.append(c("Town Tune Editor (compact)", "36"))
        lines.append("")
        lines.append(build_row(0))
        lines.append(build_row(8))
        lines.append("")
        lines.append(c("Terminal too small for staff view.", "33"))
        if status:
            lines.append(c(status, "35"))
        if len(lines) < term_rows:
            lines.extend([""] * (term_rows - len(lines)))
        elif len(lines) > term_rows:
            lines = lines[:term_rows]
        return lines

    if term_rows < required_rows or term_cols < total_w + 2:
        return compact()

    def cell_for(tok):
        if tok == TOWN_TUNE_REST:
            return "-- "
        if tok == TOWN_TUNE_HOLD:
            return "== "
        return f"{tok:<3}"

    def cursor_row(start_idx):
        cells = []
        for i in range(start_idx, start_idx + row_w):
            if i == cursor:
                cells.append("^".center(cell_w))
            else:
                cells.append(" " * cell_w)
        return pad_s + (" " * gap).join(cells)

    def build_staff(start_idx):
        lines = []
        # High notes at top
        for y in range(staff_h):
            pitch = TOWN_TUNE_NOTES[staff_h - 1 - y]
            is_staff = (y % 2 == 1)
            cells = []
            for i in range(start_idx, start_idx + row_w):
                tok = notes[i]
                cell = ("-" * cell_w) if is_staff else (" " * cell_w)
                if tok == pitch:
                    cell = cell_for(tok)
                elif tok in (TOWN_TUNE_REST, TOWN_TUNE_HOLD) and y == staff_h // 2:
                    cell = cell_for(tok)
                if i == cursor and tok == pitch:
                    cell = c(cell, "38;5;226") if USE_COLOR else cell
                cells.append(cell)
            lines.append(pad_s + (" " * gap).join(cells))
        return lines

    lines = []
    lines.append(c("Town Tune Editor (16 steps)", "36"))
    lines.append("")
    lines.append(cursor_row(0))
    lines.extend(build_staff(0))
    lines.append("")
    lines.append(cursor_row(8))
    lines.extend(build_staff(8))
    lines.append("")
    help_line = "Arrows: move/change pitch  r=rest  h=hold  p=preview  s=save  q=save+quit"
    lines.append(c(help_line, "33"))
    if status:
        lines.append(c(status, "35"))

    if len(lines) < term_rows:
        lines.extend([""] * (term_rows - len(lines)))
    elif len(lines) > term_rows:
        lines = lines[:term_rows]
    return lines

def run_tune_editor(audio_device=None):
    notes = load_town_tune()
    cursor = 0
    status = None
    last_lines = None
    preview_proc = None
    preview_tmp = None

    def stop_preview():
        nonlocal preview_proc, preview_tmp
        if preview_proc and preview_proc.poll() is None:
            try:
                preview_proc.terminate()
            except Exception:
                pass
        preview_proc = None
        if preview_tmp:
            try:
                os.unlink(preview_tmp)
            except Exception:
                pass
            preview_tmp = None

    try:
        while True:
            lines = _render_tune_editor(notes, cursor, status=status)
            if lines != last_lines:
                render(lines)
                last_lines = list(lines)
            status = None

            key = _read_key(sys.stdin.fileno(), timeout=0.2)
            if not key:
                continue
            if key in ("q", "Q", "ESC"):
                save_town_tune(notes)
                stop_preview()
                return
            if key in ("s", "S"):
                save_town_tune(notes)
                status = f"Saved: {TOWN_TUNE_PATH}"
                continue
            if key in ("p", "P"):
                stop_preview()
                preview_proc, preview_tmp = spawn_town_tune(audio_device)
                if preview_proc:
                    status = "Previewing tune..."
                else:
                    status = "Preview unavailable (fluidsynth or soundfont missing)."
                continue
            if key in ("LEFT",):
                cursor = (cursor - 1) % TOWN_TUNE_STEPS
                continue
            if key in ("RIGHT",):
                cursor = (cursor + 1) % TOWN_TUNE_STEPS
                continue
            if key in ("r", "R"):
                notes[cursor] = TOWN_TUNE_REST
                continue
            if key in ("h", "H"):
                notes[cursor] = TOWN_TUNE_HOLD
                continue
            if key in ("UP", "DOWN"):
                choices = list(TOWN_TUNE_NOTES) + [TOWN_TUNE_REST, TOWN_TUNE_HOLD]
                cur = notes[cursor]
                try:
                    idx = choices.index(cur)
                except Exception:
                    idx = 0
                if key == "UP":
                    idx = (idx + 1) % len(choices)
                else:
                    idx = (idx - 1) % len(choices)
                notes[cursor] = choices[idx]
                continue
    finally:
        stop_preview()

def truncate_plain(s, maxlen):
    if maxlen <= 0:
        return ""
    if len(s) <= maxlen:
        return s
    if maxlen <= 1:
        return s[:maxlen]
    return s[: maxlen - 3] + "..." if maxlen >= 3 else s[:maxlen]

def truncate_ansi_visible(s, maxlen):
    if maxlen <= 0:
        return ""
    out = []
    visible = 0
    i = 0
    while i < len(s):
        ch = s[i]
        if ch == "\x1b" and i + 1 < len(s) and s[i + 1] == "[":
            # copy ANSI escape without counting visible width
            end = i + 2
            while end < len(s) and s[end] != "m":
                end += 1
            end = min(end + 1, len(s))
            out.append(s[i:end])
            i = end
            continue
        if visible >= maxlen:
            break
        out.append(ch)
        visible += 1
        i += 1
    if visible >= maxlen:
        out.append("\x1b[0m")
    return "".join(out)

def build_title_art(text, width):
    if not SHOW_TITLE_ART:
        return [], False, [], None
    if shutil.which("figlet") is None:
        return [], False, [], None
    try:
        art = subprocess.check_output(
            ["figlet", "-w", str(max(10, width)), text],
            text=True,
        )
        base_lines = [ln.rstrip("\n") for ln in art.splitlines()]
        lines = list(base_lines)
        lolcat_path = shutil.which("lolcat")
        if lolcat_path is None:
            for candidate in ("/usr/games/lolcat", "/usr/bin/lolcat", "/bin/lolcat"):
                if os.path.exists(candidate) and os.access(candidate, os.X_OK):
                    lolcat_path = candidate
                    break
        if USE_COLOR and lolcat_path is not None:
            try:
                colored = subprocess.check_output(
                    [lolcat_path, "-f"],
                    input="\n".join(base_lines),
                    text=True,
                )
                lines = [ln.rstrip("\n") for ln in colored.splitlines()]
                return lines, True, base_lines, lolcat_path
            except Exception:
                return lines, False, base_lines, lolcat_path
        return lines, False, base_lines, lolcat_path
    except Exception:
        return [], False, [], None


