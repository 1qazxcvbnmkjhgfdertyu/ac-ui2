            up_plain = [up_title_trunc, "(no candidates)"]
            up_plain = [truncate_plain(s, panel_max_width) for s in up_plain]
            up_color = [c(up_title_trunc, "36"), c("(no candidates)", "2")]
        up_box, up_w = build_box(up_plain, up_color)

    if hist_box and up_box:
        panel_height = max(len(hist_box), len(up_box))
    elif hist_box:
        panel_height = len(hist_box)
    elif up_box:
        panel_height = len(up_box)
    else:
        panel_height = 0
    if panel_height and (len(lines) + panel_height + min_spectrum_rows + 1 > term_rows):
        hist_box = None
        up_box = None

    if hist_box and up_box:
        total_w = (hist_w + 4) + (up_w + 4)
        if total_w + 3 <= term_cols:
            target_len = max(len(hist_box), len(up_box))
            hist_box = pad_box_lines(hist_box, hist_w, target_len)
            up_box = pad_box_lines(up_box, up_w, target_len)
            for left, right in zip(hist_box, up_box):
                lines.append(left + "   " + right)
        else:
            lines.extend(hist_box)
            lines.extend(up_box)
    elif hist_box:
        lines.extend(hist_box)
    elif up_box:
        lines.extend(up_box)

    while lines and lines[-1].strip() == "" and (len(lines) + min_spectrum_rows + 1 > term_rows):
        lines.pop()

    prefix = "  "
    rows_used = len(lines)
    available_rows = max(0, term_rows - rows_used - 1)
    spectrum_height_dyn = min(spectrum_height, max(0, available_rows))
    bars_len = max(10, term_cols - len(prefix) - CAVA_MARGIN)
    mock_bars = [((i % 7) + 1) / 8 for i in range(max(CAVA_MIN_BARS, bars_len))]
    if spectrum_height_dyn > 0:
        bars = mock_bars[:bars_len]
        lines.extend([prefix + ln for ln in spectrum_lines(bars, height=spectrum_height_dyn, use_color=False, mode="bars")])
        lines.append(prefix + ("-" * bars_len))

    if len(lines) < term_rows:
        lines.extend([""] * (term_rows - len(lines)))
    elif len(lines) > term_rows:
        lines = lines[:term_rows]
    return [strip_ansi(ln) for ln in lines]

