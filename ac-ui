def drop_first_visible(s):
    if not s:
        return s
    if not USE_COLOR:
        return s[1:]
    # remove the first colorized char (e.g., \x1b[38;5;245m+\x1b[0m)
    return re.sub(r"^\x1b\[[0-9;]*m.\x1b\[0m", "", s, count=1)

